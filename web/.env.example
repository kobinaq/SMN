# Production: set to your real origin (https://….vercel.app or custom domain).
# Required for Payload admin cookies / server functions on Vercel.
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_WHATSAPP_INVITE=https://chat.whatsapp.com/your-invite
OPS_EMAIL=hello@socialmarketers.network
RESEND_API_KEY=
RESEND_FROM=Social Marketers Network <noreply@yourdomain.com>
MAILCHIMP_API_KEY=
MAILCHIMP_AUDIENCE_ID=
MAILCHIMP_SERVER_PREFIX=

# Required on Vercel (use a long random string — do not commit real secrets)
PAYLOAD_SECRET=change-me-to-a-long-random-string

# Database
# Local SQLite (default):
# DATABASE_URL=file:./payload.db
# Production Postgres (Neon / Supabase):
# DATABASE_URL=postgresql://user:pass@host/db?sslmode=require
#
# On Vercel without a remote DB, public pages use seed content.
# Member auth needs a durable DB (Postgres recommended for production).

# Force seed content for marketing pages even if a DB is configured
# USE_SEED_CONTENT=true

# Cloudflare R2 (optional locally; recommended in production for Media)
# R2_BUCKET=smn-media
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_ENDPOINT=https://<accountid>.r2.cloudflarestorage.com
# R2_REGION=auto
# R2_PUBLIC_URL=https://media.yourdomain.com

# Secures the daily Vercel opportunity import (use 16+ random characters)
CRON_SECRET=
