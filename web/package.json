{
  "name": "web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit --pretty false",
    "test": "npm run test:unit && npm run test:e2e",
    "test:unit": "vitest run",
    "test:e2e": "npm run build && node scripts/run-e2e.mjs",
    "test:coverage": "vitest run --coverage",
    "payload": "payload",
    "generate:importmap": "esbuild src/payload.config.ts --bundle --platform=node --format=esm --packages=external --outfile=scripts/.payload.config.bundle.mjs && node scripts/with-retry.mjs node scripts/gen-importmap.mjs",
    "prebuild": "npm run generate:importmap",
    "generate:types": "esbuild ./src/payload.config.ts --bundle --platform=node --format=esm --packages=external --outfile=./scripts/.payload.config.bundle.mjs && node scripts/with-retry.mjs node ./scripts/generate-types.mjs",
    "db:push": "esbuild src/payload.config.ts --bundle --platform=node --format=esm --packages=external --outfile=scripts/.payload.config.bundle.mjs && node scripts/with-retry.mjs node scripts/push-schema.mjs",
    "db:migrate:create": "esbuild ./src/payload.config.ts --bundle --platform=node --format=esm --packages=external --outfile=./scripts/.payload.config.bundle.mjs && node ./scripts/create-migration.mjs",
    "db:migrate": "esbuild ./src/payload.config.ts --bundle --platform=node --format=esm --packages=external --outfile=./scripts/.payload.config.bundle.mjs && node ./scripts/run-migrations.mjs",
    "db:migrate:adopt": "esbuild ./src/payload.config.ts --bundle --platform=node --format=esm --packages=external --outfile=./scripts/.payload.config.bundle.mjs && node ./scripts/adopt-migration-baseline.mjs",
    "db:check": "node scripts/check-schema.mjs",
    "db:ensure-sqlite": "esbuild src/payload.config.ts --bundle --platform=node --format=esm --packages=external --outfile=scripts/.payload.config.bundle.mjs && node scripts/with-retry.mjs node scripts/ensure-sqlite-schema.mjs",
    "seed:demo": "esbuild src/payload.config.ts --bundle --platform=node --format=esm --packages=external --outfile=scripts/.payload.config.bundle.mjs && node scripts/with-retry.mjs node scripts/seed-demo.mjs"
  },
  "dependencies": {
    "@payloadcms/db-postgres": "^3.85.2",
    "@payloadcms/db-sqlite": "^3.85.2",
    "@payloadcms/next": "^3.85.2",
    "@payloadcms/richtext-lexical": "^3.85.2",
    "@payloadcms/storage-s3": "^3.85.2",
    "@payloadcms/ui": "^3.85.2",
    "clsx": "^2.1.1",
    "dotenv": "^17.4.2",
    "framer-motion": "^12.42.2",
    "gsap": "^3.15.0",
    "lenis": "^1.3.25",
    "lucide-react": "^1.24.0",
    "next": "16.2.10",
    "payload": "^3.85.2",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "resend": "^6.17.2",
    "sharp": "^0.34.5",
    "tailwind-merge": "^3.6.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20.19.43",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitest/coverage-v8": "^4.1.10",
    "esbuild": "^0.28.1",
    "eslint": "^9",
    "eslint-config-next": "16.2.10",
    "sass": "^1.101.0",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^4.1.10"
  },
  "allowScripts": {
    "sharp@0.34.5": true
  }
}
